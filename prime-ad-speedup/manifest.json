{
    "manifest_version": 3,
    "name": "Prime Ad Speedup",
    "version": "0.1.0",
    "description": "Speed up Prime Video ads.",
    "host_permissions": [
        "https://www.amazon.co.jp/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://www.amazon.co.jp/gp/video/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}